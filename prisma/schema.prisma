generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id             String   @id @default(cuid())
  identificacion String   @unique
  password       String
  name           String
  role           String   @default("admin")
  createdAt      DateTime @default(now())
}

model Candidato {
  id                  String     @id @default(cuid())
  nombre              String
  cedula              String     @unique
  email               String
  telefono            String
  direccion           String
  puesto              String
  experiencia         String?
  disponibilidad      String?
  estado              String     @default("pendiente")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  aniosExperiencia    Int        @default(0)
  cursoBasicoPolicial Boolean    @default(false)
  licenciaConducir    String?
  portacionArma       Boolean    @default(false)
  tipoDocumento       String     @default("cedula")
  fechaNacimiento     DateTime?
  paisOrigen          String?
  atestados           Atestado[]

  @@index([estado])
  @@index([puesto])
}

model Atestado {
  id          String    @id @default(cuid())
  nombre      String
  url         String
  tipo        String
  candidatoId String
  createdAt   DateTime  @default(now())
  candidato   Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@index([candidatoId])
}

model Trabajador {
  id               String               @id @default(cuid())
  nombre           String
  cedula           String               @unique
  email            String
  telefono         String
  puesto           String
  ubicacion        String
  activo           Boolean              @default(true)
  despedido        Boolean              @default(false)
  fechaDespido     DateTime?
  password         String?
  createdAt        DateTime             @default(now())
  activado         Boolean              @default(false)
  codigoActivacion String?              @unique
  // Campos equivalentes a Candidato (opcionales para compatibilidad)
  tipoDocumento       String?
  fechaNacimiento     DateTime?
  paisOrigen          String?
  direccion           String?
  experiencia         String?   @db.Text
  aniosExperiencia    Int?
  disponibilidad      String?
  portacionArma       Boolean   @default(false)
  licenciaConducir    String?
  cursoBasicoPolicial Boolean   @default(false)

  bitacoras        Bitacora[]
  registros        RegistroHorario[]
  rondas           Ronda[]
  credenciales     WebAuthnCredential[]

  @@index([activo])
  @@index([despedido])
}

model WebAuthnCredential {
  id           String     @id @default(cuid())
  trabajadorId String
  credentialId String     @unique
  publicKey    Bytes
  counter      BigInt     @default(0)
  deviceName   String?
  createdAt    DateTime   @default(now())
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@index([trabajadorId])
}

model RegistroHorario {
  id           String     @id @default(cuid())
  trabajadorId String
  tipo         String
  fecha        DateTime   @default(now())
  ubicacion    String?
  nota         String?
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@index([trabajadorId, fecha])
}

model PuntoRuta {
  id        String         @id @default(cuid())
  nombre    String
  ubicacion String
  orden     Int
  createdAt DateTime       @default(now())
  escaneos  EscaneoRonda[]

  @@unique([ubicacion, orden])
  @@index([ubicacion])
}

model Ronda {
  id            String         @id @default(cuid())
  trabajadorId  String
  fecha         DateTime       @default(now())
  ubicacion     String
  observaciones String?
  novedades     String?
  completada    Boolean        @default(false)
  totalPuntos   Int            @default(0)
  escaneos      EscaneoRonda[]
  trabajador    Trabajador     @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@index([trabajadorId, fecha])
}

model EscaneoRonda {
  id          String    @id @default(cuid())
  rondaId     String
  puntoRutaId String
  fecha       DateTime  @default(now())
  puntoRuta   PuntoRuta @relation(fields: [puntoRutaId], references: [id], onDelete: Cascade)
  ronda       Ronda     @relation(fields: [rondaId], references: [id], onDelete: Cascade)

  @@unique([rondaId, puntoRutaId])
  @@index([rondaId])
}

model Bitacora {
  id             String     @id @default(cuid())
  trabajadorId   String
  fecha          DateTime   @default(now())
  incidencias    String
  entregaA       String
  ubicacion      String     @map("puesto")
  estado         String     @default("abierto")
  severidad      String     @default("media")
  tipoIncidencia String?
  trabajador     Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@index([trabajadorId, fecha])
}

model Notificacion {
  id        String   @id @default(cuid())
  tipo      String
  titulo    String
  mensaje   String
  link      String?
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([leida, createdAt])
}

model AuditoriaLog {
  id          String   @id @default(cuid())
  adminId     String
  adminNombre String
  accion      String
  entidad     String
  entidadId   String?
  detalle     String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
}

model Ubicacion {
  id        String   @id @default(cuid())
  nombre    String   @unique
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([activa])
}
